import numpy as np
from PIL import Image
import pandas as pd
from collections import defaultdict
from pathlib import Path
import time

#НАСТРОЙКИ
mask_dir = Path("PavementDamagesG-7/masks") 

class_colors = {
    (0, 0, 0): "Background",
    (250, 50, 83): "Cracks",
    (61, 245, 61): "Alligator",
    (42, 125, 209): "Potholes",
    (245, 147, 49): "Markings",
    (115, 51, 128): "Drains",
    (250, 250, 55): "Patching"
}

#ЗАПУСК
