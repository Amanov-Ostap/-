# Универсальная функция
def filter_group(df, conditions, name):
    filtered = df[conditions]
    pct = len(filtered) / len(df) * 100
    print(f"{name}: {len(filtered)} ({pct:.1f}%)")
    return filtered

risky = filter_group(df,
    (df['Age'] > 55) & (df['Cholesterol'] > 250) & (df['Number of vessels fluro'] > 1),
    "Группа риска")
