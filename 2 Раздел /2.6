import wfdb
import matplotlib.pyplot as plt
import numpy as np

# ========================= НАСТРОЙКИ =========================
record_name = '800'          # ← Меняй здесь: 800, 850, 811, 873, 890 и т.д.
path = 'mit-bih-supraventricular-arrhythmia-database-1.0.0'

sec_to_show = 60             # Сколько секунд показывать на временных графиках

# ========================= ЗАГРУЗКА =========================
record = wfdb.rdrecord(f'{path}/{record_name}')

sig1 = record.p_signal[:, 0]   # Канал 1 (полный сигнал)
sig2 = record.p_signal[:, 1]   # Канал 2 (полный сигнал)

# ========================= КОРРЕЛЯЦИОННЫЙ АНАЛИЗ =========================
print("=== КОРРЕЛЯЦИОННЫЙ АНАЛИЗ МЕЖДУ КАНАЛАМИ ===")

# Pearson correlation (линейная связь)
pearson_corr = np.corrcoef(sig1, sig2)[0, 1]

# Spearman correlation (монотонная связь, устойчив к выбросам)
from scipy.stats import spearmanr
spearman_corr, _ = spearmanr(sig1, sig2)

print(f"Pearson  корреляция (линейная):   {pearson_corr:.4f}")
print(f"Spearman корреляция (ранговая):   {spearman_corr:.4f}")

if abs(pearson_corr) > 0.8:
    print("→ Очень сильная положительная корреляция между каналами")
elif abs(pearson_corr) > 0.6:
    print("→ Сильная положительная корреляция")
elif abs(pearson_corr) > 0.4:
    print("→ Умеренная корреляция")
else:
    print("→ Слабая корреляция (каналы довольно независимы)")

print(f"\nИнтерпретация: коэффициент близок к 1 — каналы сильно синхронизированы (типично для ЭКГ)")

# ========================= ВИЗУАЛИЗАЦИЯ =========================
samples = int(sec_to_show * record.fs)
time = np.arange(samples) / record.fs

sig1_show = sig1[:samples]
sig2_show = sig2[:samples]

fig, axs = plt.subplots(2, 2, figsize=(16, 10), constrained_layout=True)

# 1. Временные ряды (overlay)
axs[0, 0].plot(time, sig1_show, color='#1f77b4', linewidth=0.9, label='Канал 1')
axs[0, 0].plot(time, sig2_show, color='#ff7f0e', linewidth=0.9, label='Канал 2', alpha=0.85)
axs[0, 0].set_title(f'Запись {record_name} — Первые {sec_to_show} секунд')
axs[0, 0].set_ylabel('Амплитуда (mV)')
axs[0, 0].legend()
axs[0, 0].grid(True, alpha=0.3)

# 2. Scatter plot (downsampled для наглядности)
downsample = 10
axs[0, 1].scatter(sig1[::downsample], sig2[::downsample], alpha=0.3, s=8, color='#2ca02c')
axs[0, 1].set_title('Scatter plot: Канал 1 vs Канал 2 (весь сигнал)')
axs[0, 1].set_xlabel('Амплитуда Канал 1 (mV)')
axs[0, 1].set_ylabel('Амплитуда Канал 2 (mV)')
axs[0, 1].grid(True, alpha=0.3)

# Добавляем линию регрессии
z = np.polyfit(sig1[::downsample], sig2[::downsample], 1)
p = np.poly1d(z)
axs[0, 1].plot(sig1[::downsample], p(sig1[::downsample]), "r--", linewidth=1.5, label=f'y = {z[0]:.3f}x + {z[1]:.3f}')
axs[0, 1].legend()

# 3. Гистограмма распределения Канал 1
axs[1, 0].hist(sig1, bins=200, color='#1f77b4', alpha=0.8, edgecolor='black')
axs[1, 0].set_title('Распределение значений — Канал 1')
axs[1, 0].set_xlabel('Амплитуда (mV)')
axs[1, 0].set_ylabel('Количество сэмплов')
axs[1, 0].grid(True, alpha=0.3)

# 4. Гистограмма распределения Канал 2
axs[1, 1].hist(sig2, bins=200, color='#ff7f0e', alpha=0.8, edgecolor='black')
axs[1, 1].set_title('Распределение значений — Канал 2')
axs[1, 1].set_xlabel('Амплитуда (mV)')
axs[1, 1].set_ylabel('Количество сэмплов')
axs[1, 1].grid(True, alpha=0.3)

plt.suptitle(f'Корреляционный анализ — Запись {record_name}\n'
             f'Pearson = {pearson_corr:.4f} | Spearman = {spearman_corr:.4f}',
             fontsize=15, fontweight='bold')

plt.show()
